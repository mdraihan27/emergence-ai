APP_NAME=Dhaka Emergency Response API
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=*

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=dhaka_emergency

JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# Optional. If empty, admin endpoints are open inside your private environment.
ADMIN_API_KEY=

# Dummy OTP used for responder login verification
DUMMY_OTP=123456

# Gemini free tier key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Whisper model options: tiny, base, small, medium, large
WHISPER_MODEL=tiny
WHISPER_LANGUAGE=bn

MAX_DISPATCH_RESPONDERS=5
SEVERITY_ESCALATION_THRESHOLD=4
